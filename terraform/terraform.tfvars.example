# Copy this file to terraform.tfvars and fill in your values
# NEVER commit terraform.tfvars to git (it's in .gitignore)

# ── Required ──────────────────────────────────────────────
aws_region   = "eu-west-2"
project_name = "ecommerce"
environment  = "prod"

# CHANGE THIS — use a strong password (12+ chars, mixed case, numbers, symbols)
db_password = "CHANGEME_SuperSecure123!"

# Email address to receive CloudWatch alarm notifications
alert_email = "yourname@example.com"

# ── Optional overrides (defaults are fine to start) ───────
# kubernetes_version      = "1.29"
# node_instance_type      = "t3.medium"
# node_group_min_size     = 2
# node_group_max_size     = 6
# node_group_desired_size = 3
# db_instance_class       = "db.t3.micro"
# db_allocated_storage    = 20
# db_multi_az             = true    # Set to false for dev to save ~$14/mo
# s3_force_destroy        = false   # Set to true for dev environments
